  "code_formatting": {
    "spacing": {
      "after_opening_brackets": true,
      "before_closing_brackets": true,
      "before_equals": true,
      "after_equals": true,
      "equals_in_keyword_arguments": true,
      "equals_in_default_parameters": true,
      "fstring_format_specifiers": "NO spaces inside f-string format specs — f\"{value:.2f}\" NOT f\"{ value:.2f }\"",
      "description": "Space before and after = in ALL contexts: assignments, keyword arguments, and default parameter values. Bracket spacing does NOT apply inside f-string format specifiers."
    },
    "bracket_spacing_examples": {
      "parentheses": "function( param1, param2 )",
      "square_brackets": "array[ index ]",
      "curly_braces": "dict{ key: value }",
      "assignment": "variable = value",
      "keyword_argument": "function( key = value )",
      "default_parameter": "def myMethod( self, param = None ):",
      "fstring_correct": "f\"{value:.2f}\"",
      "fstring_incorrect": "f\"{ value:.2f }\""
    }
  },
  "workflow_preferences": {
    "git": {
      "always_use_side_branch": true,
      "never_work_directly_on_master": true,
      "auto_create_feature_branch": true,
      "never_merge_without_permission": true,
      "update_master_after_merge": true,
      "create_new_branch_after_merge": true,
      "commit_each_working_subject": true,
      "branch_naming_pattern": "feature/{description}",
      "description": "Git workflow and branch management preferences"
    },
    "development": {
      "commit_frequently": true,
      "descriptive_commit_messages": true,
      "test_before_merge": true,
      "maintain_clean_history": true,
      "order_imports_short_to_long": true,
      "avoid_getattr_hasattr": true,
      "avoid_pyramid_of_doom": true,
      "use_try_except_with_custom_exceptions": true,
      "max_nested_if_levels": 2,
      "prefer_early_return": true
    },
    "branch_examples": {
      "feature_branch": "feature/add-new-component",
      "bugfix_branch": "bugfix/fix-camera-positioning",
      "refactor_branch": "refactor/improve-performance",
      "experimental_branch": "experimental/try-new-approach"
    },
    "merge_workflow": {
      "steps": [
        "1. Get permission before merging",
        "2. Test all changes thoroughly",
        "3. Merge feature branch to master",
        "4. Switch to master and pull latest",
        "5. Create new feature branch for next work"
      ]
    },
    "code_quality": {
      "exception_patterns": {
        "custom_exceptions": "class CustomError(Exception): pass",
        "try_except_preferred": "try: action() except CustomError as e: handle(e)",
        "avoid_nested_if": "Use early returns instead of nested if statements"
      },
      "structure_patterns": {
        "early_return": "if not condition: return early_result",
        "guard_clauses": "Validate inputs at function start with early returns",
        "flat_structure": "Avoid deep nesting, prefer flat conditional structure"
      }
    }
  }
