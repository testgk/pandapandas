{
  "colors": {
    "buttons": {
      "increment": {
        "background": [0.2, 0.8, 0.2, 1.0],
        "text": [0, 0, 0, 1.0],
        "hover": [0.3, 0.9, 0.3, 1.0],
        "pressed": [0.3, 0.3, 0.3, 1.0]
      },
      "control": {
        "background": [0.1, 0.3, 0.1, 1.0],
        "text": [0, 1.0, 0, 1.0],
        "hover": [0.2, 0.4, 0.2, 1.0],
        "pressed": [0.3, 0.3, 0.3, 1.0]
      },
      "label": {
        "background": [0, 0, 0, 0],
        "text": [1.0, 1.0, 1.0, 1.0]
      }
    },
    "text": {
      "log": [1.0, 1.0, 1.0, 1.0],
      "status": [0, 1.0, 0, 1.0],
      "system": [1.0, 1.0, 1.0, 1.0]
    }
  },
  "layout": {
    "buttons": {
      "increment": {
        "plus_position": [-0.75, 0, 0.8],
        "minus_position": [-0.75, 0, 0.7],
        "scale": 0.04
      },
      "zoom": {
        "label_position": [-0.1, 0, 0.8],
        "in_position": [0.1, 0, 0.8],
        "out_position": [0.3, 0, 0.8],
        "scale": 0.05
      },
      "reset": {
        "position": [0, 0, 0.65],
        "scale": 0.05
      },
      "rotation": {
        "up_position": [0, 0, 0.9],
        "down_position": [0, 0, -0.8],
        "left_position": [-0.95, 0, 0],
        "right_position": [0.95, 0, 0],
        "scale": 0.05
      },
      "presets": {
        "positions": [
          [-0.6, 0, 0.2],
          [-0.6, 0, 0.1],
          [-0.6, 0, 0.0],
          [0.6, 0, 0.2],
          [0.6, 0, 0.1],
          [0.6, 0, 0.0]
        ],
        "scale": 0.04
      }
    },
    "text": {
      "log_position": [0, -0.75],
      "log_scale": 0.04,
      "log_wordwrap": 80,
      "status_position": [0, -0.85],
      "status_scale": 0.04
    }
  },
  "effects": {
    "button_press_duration": 0.1,
    "max_log_messages": 3
  },
  "text_content": {
    "status_message": "REAL WORLD DATA • MANUAL CONTROLS ONLY",
    "system_ready": "SYSTEM READY",
    "zoom_label": "ZOOM",
    "presets": [
      "EUROPE",
      "AMERICAS",
      "ASIA",
      "AFRICA",
      "ATLANTIC",
      "PACIFIC"
    ]
  },
  "code_formatting": {
    "spacing": {
      "after_opening_brackets": true,
      "before_closing_brackets": true,
      "before_equals": true,
      "after_equals": true,
      "description": "Formatting preferences for code generation"
    },
    "bracket_spacing_examples": {
      "parentheses": "function( param1, param2 )",
      "square_brackets": "array[ index ]",
      "curly_braces": "dict{ key: value }",
      "assignment": "variable = value"
    }
  },
  "workflow_preferences": {
    "git": {
      "always_use_side_branch": true,
      "never_work_directly_on_master": true,
      "auto_create_feature_branch": true,
      "never_merge_without_permission": true,
      "update_master_after_merge": true,
      "create_new_branch_after_merge": true,
      "commit_each_working_subject": true,
      "branch_naming_pattern": "feature/{description}",
      "description": "Git workflow and branch management preferences"
    },
    "development": {
      "commit_frequently": true,
      "descriptive_commit_messages": true,
      "test_before_merge": true,
      "maintain_clean_history": true,
      "order_imports_short_to_long": true,
      "avoid_getattr_hasattr": true
    },
    "branch_examples": {
      "feature_branch": "feature/add-new-component",
      "bugfix_branch": "bugfix/fix-camera-positioning",
      "refactor_branch": "refactor/improve-performance",
      "experimental_branch": "experimental/try-new-approach"
    },
    "merge_workflow": {
      "steps": [
        "1. Get permission before merging",
        "2. Test all changes thoroughly",
        "3. Merge feature branch to master",
        "4. Switch to master and pull latest",
        "5. Create new feature branch for next work"
      ]
    }
  }
}
